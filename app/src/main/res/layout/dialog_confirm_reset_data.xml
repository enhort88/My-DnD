<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/living_worlds_panel_background"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/philosopher_bold"
        android:gravity="center"
        android:text="ОБНУЛИТЬ ВСЕ ДАННЫЕ?"
        android:textColor="#D99A82"
        android:textSize="21sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:text="Будут безвозвратно удалены все миры, таймлайны, герои, кампании, журнал, инвентарь, NPC, ситуации, мировые события и summary.\n\nGGUF-модели, музыка и настройки приложения останутся."
        android:textColor="#D7CFC0"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/cancelResetDataButton"
            style="@style/FantasyButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="ОТМЕНА"
            android:textSize="14sp" />

        <Space
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/confirmResetDataButton"
            style="@style/FantasyButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="ОБНУЛИТЬ"
            android:textColor="#D99A82"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>
