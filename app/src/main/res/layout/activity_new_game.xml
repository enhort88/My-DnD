<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#171512"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/newGameStageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1 из 3 — Мир"
            android:textColor="#E8D8A8"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/newGameHelpText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Опишите, какой мир вы хотите."
            android:textColor="#C7BFAF"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/newGameRequestEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:backgroundTint="#A98A55"
            android:gravity="top|start"
            android:hint="Мрачное фэнтези после гражданской войны..."
            android:minHeight="120dp"
            android:minLines="5"
            android:padding="10dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#777777" />

        <Button
            android:id="@+id/newGameGenerateButton"
            style="@style/FantasyButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="14dp"
            android:text="СГЕНЕРИРОВАТЬ" />

        <TextView
            android:id="@+id/newGameStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textColor="#9E9688"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/newGamePreviewText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#B0201D19"
            android:padding="14dp"
            android:textColor="#E8E0D0"
            android:textIsSelectable="true"
            android:textSize="16sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/newGameDecisionPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/newGameConfirmButton"
                style="@style/FantasyButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="ПОДТВЕРДИТЬ" />

            <Button
                android:id="@+id/newGameRegenerateButton"
                style="@style/FantasyButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:text="СГЕНЕРИРОВАТЬ ЗАНОВО" />
        </LinearLayout>

        <Button
            android:id="@+id/newGameBackButton"
            style="@style/FantasyButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:text="НАЗАД" />

    </LinearLayout>
</ScrollView>
