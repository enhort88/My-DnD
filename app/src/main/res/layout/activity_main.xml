<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/appRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#151515"
    android:fitsSystemWindows="true">


    <!-- ФОН ГЛАВНОГО МЕНЮ -->

    <ImageView
        android:id="@+id/welcomeBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/main_menu_bg" />


    <!-- ФОН ИГРОВОГО ЭКРАНА -->

    <ImageView
        android:id="@+id/gameBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/game_bg"
        android:visibility="gone" />


    <!-- ==================== -->
    <!--    ГЛАВНОЕ МЕНЮ      -->
    <!-- ==================== -->

    <LinearLayout
        android:id="@+id/welcomeLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@android:color/transparent"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">


        <!-- Верхнее свободное место -->

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />


        <!-- Заголовок -->

        <TextView
            android:id="@+id/titleTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:translationY="-110dp"
            android:text="Pocket"
            android:textColor="#E7C77C"
            android:textSize="54sp"
            android:fontFamily="@font/cinzel_decorative_regular"
            android:letterSpacing="0.03"
            android:shadowColor="#E0000000"
            android:shadowDx="0"
            android:shadowDy="4"
            android:shadowRadius="10" />


        <!-- Подзаголовок -->

<!--        <TextView-->
<!--            android:id="@+id/subtitleTextView"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_marginTop="8dp"-->
<!--            android:gravity="center"-->
<!--            android:text="Подземелье и драконы в кармане"-->
<!--            android:textColor="#B8B0A0"-->
<!--            android:textSize="16sp"-->
<!--            android:fontFamily="@font/philosopher_bold" />-->


        <!--
            ВЕСЬ БЛОК КНОПОК.

            Именно translationY сдвигает все 4 кнопки вниз.
            Сейчас стоит 130dp — примерно высота двух кнопок.
        -->

        <LinearLayout
            android:id="@+id/menuButtonsLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:translationY="130dp">


            <Button
                android:id="@+id/startGameButton"
                style="@style/FantasyButton"
                android:layout_width="300dp"
                android:layout_height="56dp"
                android:text="НОВАЯ ИГРА" />


            <Button
                android:id="@+id/continueGameButton"
                style="@style/FantasyButton"
                android:layout_width="300dp"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:text="ПРОДОЛЖИТЬ" />


            <Button
                android:id="@+id/loadGamesButton"
                style="@style/FantasyButton"
                android:layout_width="300dp"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:text="ЗАГРУЗИТЬ ИГРУ" />


            <Button
                android:id="@+id/settingsButton"
                style="@style/FantasyButton"
                android:layout_width="300dp"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:text="НАСТРОЙКИ" />


            <Button
                android:id="@+id/exitButton"
                style="@style/FantasyButton"
                android:layout_width="300dp"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:text="ВЫХОД" />


            <Button
                android:id="@+id/helpButton"
                style="@style/FantasySendButton"
                android:layout_width="54dp"
                android:layout_height="44dp"
                android:layout_marginTop="10dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text="\?"
                android:textSize="18sp" />

        </LinearLayout>


        <!-- Нижнее свободное место -->

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />


        <!-- Автор -->

<!--        <TextView-->
<!--            android:id="@+id/authorTextView"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:gravity="center"-->
<!--            android:paddingBottom="8dp"-->
<!--            android:text="Artem Ponikarov&#10;enhort@gmail.com"-->
<!--            android:textColor="#887D70"-->
<!--            android:textSize="12sp"-->
<!--            android:fontFamily="@font/philosopher_bold" />-->

    </LinearLayout>


    <!-- ==================== -->
    <!--     ИГРОВОЙ ЭКРАН    -->
    <!-- ==================== -->

    <LinearLayout
        android:id="@+id/gameLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@android:color/transparent"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="28dp"
        android:paddingBottom="12dp">


        <!-- Быстрые настройки игры -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal"
            android:paddingBottom="4dp">

            <Button
                android:id="@+id/gameSettingsButton"
                style="@style/FantasySendButton"
                android:layout_width="46dp"
                android:layout_height="42dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="⚙"
                android:textSize="20sp" />

        </LinearLayout>


        <!-- История игры -->

        <ScrollView
            android:id="@+id/chatScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:background="@android:color/transparent">


            <TextView
                android:id="@+id/chatTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:text="Игра ещё не началась..."
                android:textColor="#E8E0D0"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp" />

        </ScrollView>


        <!-- Настройки thinking -->

        <LinearLayout
            android:id="@+id/optionsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

        </LinearLayout>


        <!-- Панель ввода -->

        <LinearLayout
            android:id="@+id/inputPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp">


            <!-- Поле ввода сделано выше, чтобы длинное действие было удобнее читать -->

            <EditText
                android:id="@+id/inputEditText"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:hint="Что ты делаешь?"
                android:textColor="#FFFFFF"
                android:textColorHint="#777777"
                android:backgroundTint="#A98A55"
                android:gravity="top|start"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:minLines="2"
                android:maxLines="5"
                android:singleLine="false" />


            <!-- Быстрый доступ к состоянию кампании -->

            <LinearLayout
                android:id="@+id/gameInfoButtonsPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">


                <Button
                    android:id="@+id/characterButton"
                    style="@style/FantasySendButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="Персонаж"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="8sp"
                    android:autoSizeMaxTextSize="13sp"
                    android:autoSizeStepGranularity="1sp" />


                <Button
                    android:id="@+id/inventoryButton"
                    style="@style/FantasySendButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="Инвентарь"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="8sp"
                    android:autoSizeMaxTextSize="13sp"
                    android:autoSizeStepGranularity="1sp" />


                <Button
                    android:id="@+id/journalButton"
                    style="@style/FantasySendButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="Журнал"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="8sp"
                    android:autoSizeMaxTextSize="13sp"
                    android:autoSizeStepGranularity="1sp" />


                <Button
                    android:id="@+id/diceButton"
                    style="@style/FantasySendButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="0.72"
                    android:text="Кубик"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="9sp"
                    android:autoSizeMaxTextSize="14sp"
                    android:autoSizeStepGranularity="1sp" />

            </LinearLayout>


            <!--
                Кнопка автоматически используется как:

                Отправить
                Стоп
                Останавливаю...
                Обновляю память...
            -->

            <Button
                android:id="@+id/sendButton"
                style="@style/FantasySendButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:text="Отправить"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="9sp"
                android:autoSizeMaxTextSize="15sp"
                android:autoSizeStepGranularity="1sp" />

        </LinearLayout>


    </LinearLayout>

</FrameLayout>