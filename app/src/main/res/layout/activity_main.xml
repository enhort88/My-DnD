<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/appRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#151515"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/welcomeBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/main_menu_bg" />

    <ImageView
        android:id="@+id/gameBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/game_bg"
        android:visibility="gone" />

    <!-- Приветственное меню -->
    <!-- Приветственное меню -->
    <LinearLayout
        android:id="@+id/welcomeLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@android:color/transparent">

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/startGameButton"
            android:layout_width="239dp"
            android:layout_height="57dp"
            android:background="@android:color/transparent"
            android:backgroundTint="@android:color/transparent"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text=""
            android:translationX="-4dp"
            android:translationY="48dp" />

        <Button
            android:id="@+id/loadGameButton"
            android:layout_width="236dp"
            android:layout_height="53dp"
            android:layout_marginTop="8dp"
            android:background="@android:color/transparent"
            android:backgroundTint="@android:color/transparent"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text=""
            android:translationX="-4dp"
            android:translationY="50dp" />

        <Button
            android:id="@+id/settingsButton"
            android:layout_width="233dp"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@android:color/transparent"
            android:backgroundTint="@android:color/transparent"
            android:elevation="0dp"
            android:enabled="false"
            android:stateListAnimator="@null"
            android:text=""
            android:translationX="-4dp"
            android:translationY="53dp" />

        <Button
            android:id="@+id/exitButton"
            android:layout_width="232dp"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@android:color/transparent"
            android:backgroundTint="@android:color/transparent"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text=""
            android:translationX="-4dp"
            android:translationY="55dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Игровой экран -->
    <LinearLayout
        android:id="@+id/gameLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@android:color/transparent"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="28dp"
        android:paddingBottom="12dp">

        <ScrollView
            android:id="@+id/chatScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <TextView
                android:id="@+id/chatTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Игра ещё не началась..."
                android:textColor="#E8E0D0"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp" />

        </ScrollView>

        <LinearLayout
            android:id="@+id/optionsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <CheckBox
                android:id="@+id/useThinkingCheckBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Использовать think"
                android:textColor="#B8B0A0"
                android:checked="false" />

            <CheckBox
                android:id="@+id/showThinkingCheckBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Показывать размышления модели"
                android:textColor="#B8B0A0"
                android:checked="false" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/inputPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp">

            <EditText
                android:id="@+id/inputEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Что ты делаешь?"
                android:textColor="#FFFFFF"
                android:textColorHint="#777777"
                android:backgroundTint="#777777"
                android:minLines="1"
                android:maxLines="4"
                android:singleLine="false" />

            <Button
                android:id="@+id/sendButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Отправить"
                android:textAllCaps="false" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>