<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#151515"
    android:fitsSystemWindows="true"
    android:clipToPadding="false"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="28dp"
    android:paddingBottom="12dp">

    <ScrollView
        android:id="@+id/chatScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <TextView
            android:id="@+id/chatTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Мастер ждёт твоего первого действия..."
            android:textColor="#E8E0D0"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp" />

    </ScrollView>

    <LinearLayout
        android:id="@+id/optionsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <CheckBox
            android:id="@+id/useThinkingCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Использовать think"
            android:textColor="#B8B0A0"
            android:checked="false" />

        <CheckBox
            android:id="@+id/showThinkingCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Показывать размышления модели"
            android:textColor="#B8B0A0"
            android:checked="false" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/inputPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp">

        <EditText
            android:id="@+id/inputEditText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Что ты делаешь?"
            android:textColor="#FFFFFF"
            android:textColorHint="#777777"
            android:backgroundTint="#777777"
            android:minLines="1"
            android:maxLines="4"
            android:singleLine="false" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Отправить" />

    </LinearLayout>

</LinearLayout>