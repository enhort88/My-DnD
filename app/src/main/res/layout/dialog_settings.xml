<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/living_worlds_panel_background"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="18dp"
    android:paddingEnd="16dp"
    android:paddingBottom="14dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/philosopher_bold"
        android:gravity="center"
        android:letterSpacing="0.04"
        android:text="НАСТРОЙКИ"
        android:textColor="#D8B36A"
        android:textSize="24sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/philosopher_bold"
                android:text="ЗАДНИЙ ФОН"
                android:textColor="#E0BE78"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/settingsBackgroundButton"
                style="@style/FantasyButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="14dp"
                android:text="ФОН ИГРЫ: 1" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="#5C4932" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/philosopher_bold"
                android:text="МУЗЫКА"
                android:textColor="#E0BE78"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/settingsMusicToggleButton"
                style="@style/FantasyButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:text="МУЗЫКА: ВКЛ" />

            <TextView
                android:id="@+id/settingsVolumeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Громкость: 25%"
                android:textColor="#D7CFC0"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/settingsVolumeSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progress="25"
                android:progressTint="#C7A764"
                android:thumbTint="#E0BE78" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="#5C4932" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/philosopher_bold"
                android:text="РЕЖИМ ОТВЕТА"
                android:textColor="#E0BE78"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Настройка меняет длину художественного ответа. Логику памяти и tools не трогает."
                android:textColor="#A9A092"
                android:textSize="13sp" />

            <Button
                android:id="@+id/settingsFastModeButton"
                style="@style/FantasyButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:text="БЫСТРО" />

            <Button
                android:id="@+id/settingsNormalModeButton"
                style="@style/FantasyButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:text="✓ ОБЫЧНО" />

            <Button
                android:id="@+id/settingsAtmosphericModeButton"
                style="@style/FantasyButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:text="АТМОСФЕРНО" />

            <TextView
                android:id="@+id/settingsModeHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="2dp"
                android:textColor="#C8B58D"
                android:textSize="13sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="14dp"
                android:background="#5C4932" />

            <TextView
                android:id="@+id/settingsModelInfoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#8F887D"
                android:textSize="12sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="14dp"
                android:background="#5C4932" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/philosopher_bold"
                android:text="ДИАГНОСТИКА"
                android:textColor="#E0BE78"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Три одинаково ограниченных вопроса с коротким, средним и длинным входом. Игра и база не меняются; результаты пишутся в Logcat с тегом MyDND_BENCH."
                android:textColor="#A9A092"
                android:textSize="13sp" />

            <Button
                android:id="@+id/settingsBenchmarkButton"
                style="@style/FantasyButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:text="ТЕСТ СКОРОСТИ ×3" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="14dp"
                android:background="#5C4932" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/philosopher_bold"
                android:text="ДАННЫЕ"
                android:textColor="#D99A82"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Удаляет все миры, героев, кампании, журнал, инвентарь и память. Модели и настройки приложения останутся."
                android:textColor="#A9A092"
                android:textSize="13sp" />

            <Button
                android:id="@+id/settingsResetDataButton"
                style="@style/FantasyButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:text="ОБНУЛИТЬ ДАННЫЕ"
                android:textColor="#D99A82" />

        </LinearLayout>

    </ScrollView>

    <Button
        android:id="@+id/settingsCloseButton"
        style="@style/FantasyButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:text="ЗАКРЫТЬ" />

</LinearLayout>
