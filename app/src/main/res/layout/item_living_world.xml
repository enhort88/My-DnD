<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/living_world_card_background"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/livingWorldTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/philosopher_bold"
        android:textColor="#E0BE78"
        android:textSize="19sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/livingWorldGenreText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#A98A55"
        android:textSize="13sp"
        android:textStyle="italic" />

    <TextView
        android:id="@+id/livingWorldStateText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxLines="4"
        android:ellipsize="end"
        android:lineSpacingExtra="2dp"
        android:textColor="#E8E0D0"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/livingWorldChangesText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxLines="3"
        android:ellipsize="end"
        android:textColor="#AAA093"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/playLivingWorldButton"
            style="@style/FantasyButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="ИГРАТЬ"
            android:textSize="14sp" />

        <Space
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/deleteLivingWorldButton"
            style="@style/FantasyButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="УДАЛИТЬ"
            android:textColor="#D99A82"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>
