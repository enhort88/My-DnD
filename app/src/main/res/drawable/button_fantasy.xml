<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Отключённая кнопка -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">

            <solid android:color="#70101418" />

            <stroke
                android:width="1dp"
                android:color="#665F5038" />

            <corners android:radius="6dp" />

        </shape>
    </item>

    <!-- Нажатие -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">

            <gradient
                android:angle="90"
                android:startColor="#E03B3020"
                android:endColor="#E0171411" />

            <stroke
                android:width="2dp"
                android:color="#FFD58A" />

            <corners android:radius="6dp" />

        </shape>
    </item>

    <!-- Обычное состояние -->
    <item>
        <shape android:shape="rectangle">

            <gradient
                android:angle="90"
                android:startColor="#D5201C18"
                android:endColor="#E00D1013" />

            <stroke
                android:width="1dp"
                android:color="#B99156" />

            <corners android:radius="6dp" />

        </shape>
    </item>

</selector>