<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#E02E271D"
                android:endColor="#E0141210" />
            <stroke
                android:width="1dp"
                android:color="#E7C879" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#D8221D18"
                android:endColor="#E00D1013" />
            <stroke
                android:width="1dp"
                android:color="#8F7450" />
            <corners android:radius="8dp" />
        </shape>
    </item>

</selector>
